#!/bin/bash
# ================================================================
#  DragonPi Updater — Pull latest from GitHub & redeploy
#  Usage: dragonpi-update
# ================================================================
set -e

REPO_DIR="/opt/dragonpi"
REPO_URL="${DRAGONPI_REPO:-https://github.com/YOUR_USERNAME/dragonpi.git}"

echo "🐉 DragonPi Updater"
echo "=================="

# Clone if first time, otherwise pull
if [ ! -d "$REPO_DIR/.git" ]; then
    echo "First run — cloning repo..."
    sudo git clone "$REPO_URL" "$REPO_DIR"
    sudo chown -R dragonpi:dragonpi "$REPO_DIR"
else
    echo "Pulling latest changes..."
    cd "$REPO_DIR"
    git pull origin main
fi

echo ""
echo "Redeploying..."

# Copy files to system locations
sudo cp "$REPO_DIR/homer/config.yml" /var/www/homer/assets/config.yml
sudo cp "$REPO_DIR/nginx/dragonpi.conf" /etc/nginx/sites-available/dragonpi
sudo cp "$REPO_DIR/chatbot/app.py" /opt/dragonpi/chatbot/app.py
sudo cp "$REPO_DIR/chatbot/templates/index.html" /opt/dragonpi/chatbot/templates/index.html
sudo cp "$REPO_DIR/scripts/dragonpi-shell" /usr/local/bin/dragonpi-shell
sudo cp "$REPO_DIR/scripts/guides/"* /usr/local/bin/ 2>/dev/null || true
sudo chmod +x /usr/local/bin/dragonpi-shell /usr/local/bin/dragonpi-guide-*

# Reload services
sudo nginx -t && sudo systemctl reload nginx
sudo systemctl restart chatbot

# Update system packages
echo ""
echo "Checking for system updates..."
sudo apt update -qq && sudo apt upgrade -y -qq 2>/dev/null | tail -2

echo ""
echo "✅ DragonPi updated!"
dragonpi-status 2>/dev/null || echo "Run 'dragonpi-status' to check services"
