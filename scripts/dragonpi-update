#!/bin/bash
# ================================================================
#  DragonPi Updater — Safe pull, backup, redeploy, rollback
# ================================================================
set -e

REPO_DIR="/opt/dragonpi"
BACKUP_DIR="/opt/dragonpi/.backups"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
BACKUP_PATH="$BACKUP_DIR/$TIMESTAMP"
MAX_BACKUPS=5

echo "🐉 DragonPi Updater"
echo "=================="

# Create timestamped backup before updating
echo "Backing up current state..."
mkdir -p "$BACKUP_PATH"
for f in /var/www/homer/assets/config.yml /var/www/homer/index.html \
         /opt/dragonpi/chatbot/app.py /opt/dragonpi/chatbot/templates/index.html \
         /etc/nginx/sites-available/dragonpi.conf \
         /etc/systemd/system/chatbot.service /etc/systemd/system/ttyd.service \
         /usr/local/bin/dragonpi-shell /usr/local/bin/dragonpi-update \
         /usr/local/bin/dragonpi-guide-*; do
    [ -f "$f" ] && cp --parents "$f" "$BACKUP_PATH/" 2>/dev/null
done
# Save git hash
cd "$REPO_DIR" && git rev-parse HEAD > "$BACKUP_PATH/git-hash.txt" 2>/dev/null
echo "  Backup: $BACKUP_PATH"

# Clean old backups (keep last $MAX_BACKUPS)
ls -1d "$BACKUP_DIR"/*/ 2>/dev/null | sort -r | tail -n +$((MAX_BACKUPS+1)) | while read d; do
    rm -rf "$d" 2>/dev/null
    echo "  Pruned old backup: $(basename $d)"
done

# Pull latest from GitHub
echo ""
echo "Pulling latest from GitHub..."
cd "$REPO_DIR"
git pull origin main 2>&1 | tail -2
NEW_HASH=$(git rev-parse HEAD 2>/dev/null | cut -c1-7)
echo "  Now at: $NEW_HASH"

# Deploy non-sensitive files
echo ""
echo "Deploying..."
sudo cp "$REPO_DIR/scripts/dragonpi-shell" /usr/local/bin/dragonpi-shell
sudo cp "$REPO_DIR/scripts/dragonpi-update" /usr/local/bin/dragonpi-update
sudo cp "$REPO_DIR/scripts/guides/"* /usr/local/bin/ 2>/dev/null || true
sudo cp "$REPO_DIR/chatbot/templates/index.html" /opt/dragonpi/chatbot/templates/index.html
sudo cp "$REPO_DIR/homer/index.html" /var/www/homer/index.html
sudo cp "$REPO_DIR/nginx/dragonpi.conf" /etc/nginx/sites-available/dragonpi
sudo cp "$REPO_DIR/services/chatbot.service" /etc/systemd/system/chatbot.service
sudo chmod +x /usr/local/bin/dragonpi-shell /usr/local/bin/dragonpi-guide-* /usr/local/bin/dragonpi-update

# Reload
sudo nginx -t 2>/dev/null && sudo systemctl reload nginx
sudo systemctl daemon-reload
sudo systemctl restart chatbot 2>/dev/null || true

# System updates
echo ""
UPGRADES=$(apt list --upgradable 2>/dev/null | grep -c / || echo 0)
if [ "$UPGRADES" -gt 0 ]; then
    echo "Installing $UPGRADES system updates..."
    sudo apt update -qq 2>/dev/null && sudo apt upgrade -y -qq 2>/dev/null | tail -2
else
    echo "System up to date"
fi

echo ""
echo "✅ DragonPi updated to $NEW_HASH"
echo "   Backup: $BACKUP_PATH"
echo "   Rollback: dragonpi-rollback $TIMESTAMP"
