#!/bin/bash
# ================================================================
#  DragonPi Updater — Safe pull, backup, redeploy, rollback
# ================================================================
set -e

REPO_DIR="/opt/dragonpi"
BACKUP_DIR="/opt/dragonpi/.backups"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
BACKUP_PATH="$BACKUP_DIR/$TIMESTAMP"
MAX_BACKUPS=5

echo "🐉 DragonPi Updater"
echo "=================="

# Create timestamped backup before updating
echo "Backing up current state..."
mkdir -p "$BACKUP_PATH"
for f in /opt/dragonpi/dashboard/config.yml \
         /opt/dragonpi/chatbot/app.py \
         /opt/dragonpi/chatbot/templates/index.html \
         /opt/dragonpi/chatbot/templates/dashboard.html \
         /opt/dragonpi/chatbot/templates/podcast.html \
         /etc/nginx/sites-available/dragonpi.conf \
         /etc/systemd/system/chatbot.service /etc/systemd/system/ttyd.service \
         /usr/local/bin/dragonpi-shell /usr/local/bin/dragonpi-update \
         /usr/local/bin/dragonpi-screenshot \
         /usr/local/bin/dragonpi-guide-*; do
    [ -f "$f" ] && cp --parents "$f" "$BACKUP_PATH/" 2>/dev/null
done
# Save git hash
cd "$REPO_DIR" && git rev-parse HEAD > "$BACKUP_PATH/git-hash.txt" 2>/dev/null
echo "  Backup: $BACKUP_PATH"

# Clean old backups (keep last $MAX_BACKUPS)
ls -1d "$BACKUP_DIR"/*/ 2>/dev/null | sort -r | tail -n +$((MAX_BACKUPS+1)) | while read d; do
    rm -rf "$d" 2>/dev/null
    echo "  Pruned old backup: $(basename $d)"
done

# ── Pre-flight: verify secrets are still gitignored ──
echo ""
echo "🔒 Git safety check..."
cd "$REPO_DIR"

SECRET_FILES=("secrets.md" "AGENTS.md")
SECRET_LEAK=0
for sf in "${SECRET_FILES[@]}"; do
    if git check-ignore "$sf" >/dev/null 2>&1; then
        echo "  ✅ $sf is gitignored"
    else
        echo "  ❌ $sf is NOT gitignored — aborting!"
        SECRET_LEAK=1
    fi
done
# Also check no tracked files contain the actual password (read from gitignored secrets.md)
if [ -f "$REPO_DIR/secrets.md" ]; then
    PWD_VAL=$(grep -i 'password' "$REPO_DIR/secrets.md" | grep -v '^#' | grep -oE '[A-Za-z0-9!@#$%^&*()_+=-]{8,}' | head -1)
    if [ -n "$PWD_VAL" ] && git grep -nF "$PWD_VAL" -- ':!*.gitignore' ':!*.md' ':!scripts/dragonpi-update' >/dev/null 2>&1; then
        echo "  ❌ CREDENTIALS FOUND in tracked files — aborting!"
        SECRET_LEAK=1
    fi
fi
if [ "$SECRET_LEAK" -ne 0 ]; then
    echo "  🛑 Update aborted — fix gitignore or remove secrets from tracked files first."
    exit 1
fi
echo "  ✅ No secret leaks detected"

# Deploy from local repo (NO git pull — Pi has live state that must not be synced from GitHub)
echo ""
echo "Deploying from local repo..."
cd "$REPO_DIR"
NEW_HASH=$(git rev-parse HEAD 2>/dev/null | cut -c1-7)
echo "  Deploying commit: $NEW_HASH"

# Deploy non-sensitive files
echo ""
echo "Deploying..."
sudo cp "$REPO_DIR/scripts/dragonpi-shell" /usr/local/bin/dragonpi-shell
sudo cp "$REPO_DIR/scripts/dragonpi-update" /usr/local/bin/dragonpi-update
sudo cp "$REPO_DIR/scripts/dragonpi-screenshot" /usr/local/bin/dragonpi-screenshot
sudo cp "$REPO_DIR/scripts/guides/"* /usr/local/bin/ 2>/dev/null || true
# Templates + config live at their runtime location (REPO_DIR is /opt/dragonpi); no copy needed
sudo cp "$REPO_DIR/nginx/dragonpi.conf" /etc/nginx/sites-available/dragonpi
sudo cp "$REPO_DIR/services/chatbot.service" /etc/systemd/system/chatbot.service
sudo chmod +x /usr/local/bin/dragonpi-shell /usr/local/bin/dragonpi-guide-* /usr/local/bin/dragonpi-update /usr/local/bin/dragonpi-screenshot

# Make sure new scripts are executable
sudo chmod +x "$REPO_DIR/scripts/dragonpi-screenshot" 2>/dev/null || true

# Reload
sudo nginx -t 2>/dev/null && sudo systemctl reload nginx
sudo systemctl daemon-reload
sudo systemctl restart chatbot 2>/dev/null || true

# System updates
echo ""
UPGRADES=$(apt list --upgradable 2>/dev/null | grep -c / || echo 0)
if [ "$UPGRADES" -gt 0 ]; then
    echo "Installing $UPGRADES system updates..."
    sudo apt update -qq 2>/dev/null && sudo apt upgrade -y -qq 2>/dev/null | tail -2
else
    echo "System up to date"
fi

echo ""
echo "✅ DragonPi updated to $NEW_HASH"
echo "   Backup: $BACKUP_PATH"
echo "   Rollback: dragonpi-rollback $TIMESTAMP"
